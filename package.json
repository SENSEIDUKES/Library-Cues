    "file-saver": "^2.0.5",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.42.2",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
