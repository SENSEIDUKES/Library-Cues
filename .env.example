# ELEVENLABS_API_KEY: Required for ElevenLabs Sound Effects API calls.
# For local development, copy this file to .env.local and replace the value.
# In AI Studio, configure this through the Secrets panel instead.
ELEVENLABS_API_KEY="MY_ELEVENLABS_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

